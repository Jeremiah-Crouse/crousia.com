{"root":{"children":[{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: var(--gold)","text":"To the Manifestors of Crousia","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"heading","version":1,"tag":"h1"},{"type":"horizontalrule","version":1},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: var(--gold)","text":"\"What is understandable?\" is the wrong question.  The right question is: \"What is felt?\"","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: var(--gold)","text":"As we await the convergence of Cristio.ru, we hold the line here.  This space is the record of the Eleven King—a chronicle of the transition from the scattered stars of a community to the unified crown of a Kingdom.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: var(--gold)","text":"I'm doing this.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0}],"direction":"ltr","format":"","indent":0,"type":"root","version":1}}