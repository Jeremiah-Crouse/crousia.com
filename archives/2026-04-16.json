{"root":{"children":[{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"Hello,","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"heading","version":1,"tag":"h1"},{"children":[{"src":"/notes/note-2026-04-16-1776356407308.png","altText":"Yellow cursive handwriting on a black background.","variant":"gold","type":"image","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"I am chatting with Lauren on the phone.  She needs to make dinner but also needs to supervise the kids and the dog, while I charge my ankle monitor, miles away.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"This is our life.  At least for right now.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"src":"/notes/note-2026-04-16-1776384520096.png","altText":"Yellow handwritten text on a black background reads \"Teddy Bear the dog is on the agenda. He needs to be more socialized. Lauren is looking for active solutions. She really needs to cook dinner. Bubba has taken to throwing rocks. But we need a dog run.\"","variant":"gold","type":"image","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"Bubba pooped his diaper.  He doesn't get a chocolate pretzel.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"Esther is supposed to get on the phone at some point.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"src":"/notes/note-2026-04-16-1776385080482.png","altText":"Yellow handwritten text on a black background reads \"People believe in themselves and then project their voices. I think this is the nature of crude speech. My wife is not annoying even though she talks all the time. I say don't talk unless it's needed.\"","variant":"gold","type":"image","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"I kicked a pigeon and briefly felt bad for the pigeon.  But I told Lauren and she didn't care.  She was apparently more concerned about how we are treating the dog.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"src":"/notes/note-2026-04-16-1776385536487.png","altText":"A yellow, hand-drawn dog silhouette.","variant":"gold","type":"image","version":1},{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"This is supposed to be a dog.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"Teddy 🧸 Bear","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"heading","version":1,"tag":"h3"},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"(The dog)","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"I ❤️ this dog.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"Good boy Teddy 🧸 Bear.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"Good boy.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0}],"direction":"ltr","format":"","indent":0,"type":"root","version":1}}