{"root":{"children":[{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Job Fair Today","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"heading","version":1,"tag":"h2"},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #A020F0","text":"Àà","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"The bus comes in 7 minutes.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"I figure it's as good a time as any to leave some daily thoughts.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Although, what to talk about escapes me.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"I suppose it's just a matter of what to ","type":"text","version":1},{"detail":0,"format":3,"mode":"normal","style":"color: #FFD700","text":"think","type":"text","version":1},{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":" about, right?","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"And this should be easy.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"My thoughts are like waves of a very, very small ocean, more like ripples, because of how tiny the ocean is.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"My thoughts are like the sands in an hourglass, sitting at the bottom, as the hourglass hasn't been upended.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Well.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"My thoughts are as the bucket in a shallow well.  Unnecessary, useless, and barely beneath the surface.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Bus comes in four minutes now.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Yes, what to say what to say.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Three minutes.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Phone battery at 80%.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Friday is just beginning.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"I wonder what more I can accomplish today than handing off my resume to these folks at the San Antonio Water System.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Hmmm 🤔 ","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Sometimes an emoji is better than an ellipsis.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"...","type":"text","version":1}],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Sometimes not.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"You know actually thinking of things to say sure would beat just saying whatever I am thinking.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"heading","version":1,"tag":"h3"},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"Bus comes in one minute.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":2,"mode":"normal","style":"color: #FFD700","text":"- Jeremiah","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":2}],"direction":"ltr","format":"","indent":0,"type":"root","version":1}}