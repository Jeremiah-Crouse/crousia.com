{"root":{"children":[{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"Today, on my father-in-law's birthday, I begin to author this master document for the Income Insurance program.  What it intends to do is provide the framework for people to be able to access the intellectual resources to comprehend the flow of the economy and never make a foul move; to always know that they will be able to find what they need -- and to have that sense of providence properly represented in financial ledgers.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"- Jeremiah","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"heading","version":1,"tag":"h3"},{"children":[],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"Contributors:","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"heading","version":1,"tag":"h2"},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"(Add your name to the list if you wish)","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[{"detail":0,"format":0,"mode":"normal","style":"color: #FFD700","text":"---","type":"text","version":1}],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":0},{"children":[],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":0}],"direction":"ltr","format":"","indent":0,"type":"root","version":1}}