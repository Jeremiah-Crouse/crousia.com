{"root":{"children":[{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"From the King","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"heading","version":1,"tag":"h2"},{"children":[{"detail":0,"format":3,"mode":"normal","style":"color: #FFD700","text":"of Crousia","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":3},{"children":[],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Greetledeetle-ings.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"My ","type":"text","version":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"","text":"Amazing Prince Game","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"link","version":1,"rel":null,"target":null,"title":null,"url":"https://prince.crousia.com"},{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":" is getting better and better.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"But of course it is designed primarily with my son Ian in mind, which is why the prince has a big sister and a baby brother.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"I do still need to convert it into an installable SPA I think, like the princess game, so that it can be installed on the fire tablet at home.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Speaking of home!","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"heading","version":1,"tag":"h3"},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"My wife and I are hoping to move back in together in the next six months.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"This hinges on a number of factors, primary of which being the will of heaven.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"But I have a job fair coming up tomorrow at which I intend to approach the San Antonio Water System representatives and beg for my old job back or something similar.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"The job application has already been submitted.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Plans are, I would be able to catch back up on my child support and thus become eligible to have my licenses reinstated.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Aside from this, my wife is continuing to figure out what school she is going to teach at next year.  And I am thinking I might still eventually make my way into the future workforce as a software engineer, contingent on finishing this associates degree and whatever comes next, I hope the bachelor's degree.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"I feel I could go on forever, but assuredly I must save some thoughts for the morrow.","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[],"direction":null,"format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":1,"mode":"normal","style":"color: #FFD700","text":"Until then,","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":1},{"children":[{"detail":0,"format":3,"mode":"normal","style":"color: #FFD700","text":"- Jeremiah","type":"text","version":1}],"direction":"ltr","format":"","indent":0,"type":"paragraph","version":1,"textFormat":3}],"direction":"ltr","format":"","indent":0,"type":"root","version":1}}