PORT=5000
HOST=0.0.0.0
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_VISION_MODEL=gemini-2.0-flash-lite

# Eve local oracle
# Server-side upstream for /api/proxy/qrng. Point this at your Cloudflare randomness worker.
QRNG_UPSTREAM_URL=https://your-worker.example.workers.dev/qrng

# Browser-side overrides. Leave VITE_EVE_QRNG_URL blank to use /api/proxy/qrng.
VITE_EVE_QRNG_URL=
VITE_EVE_MODEL=Xenova/distilgpt2
VITE_EVE_DTYPE=q8

# Eve server brain + Telegram bot
OPENCODE_API_KEY=your_opencode_api_key_here
EVE_MODEL=deepseek-v4-flash-free
EVE_MEMORY_DIR=./eve-memory
EVE_CROUSIA_CONTEXT_CHARS=16000
EVE_MEMORY_CONTEXT_BYTES=12000
EVE_TELEGRAM_GROUP_LULL_MS=10000
TELEGRAM_BOT_TOKEN=your_celestial_wisdom_bot_token_here
TELEGRAM_WEBHOOK_SECRET=choose_a_long_random_secret
